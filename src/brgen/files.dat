# browser info merger
[DEFAULT where="c jc" type="e" ]
dir="binw"	usr="wbrg.exe"	cond="winhost wnthost os2host | |"	desc="Browsing information merger"	old="binb"
dir="binnt"	usr="wbrg.exe"	cond="wnthost"		where="c jc ac"	desc="Browsing information merger"
dir="axpnt"	usr="wbrg.exe"	cond="alphahost"	where="ac"	desc="Browsing information merger"
