proj_name = rescmp

wresdmp_autodepeds = .AUTODEPEND

!include cproj.mif
!include deftarg.mif
!include defrule.mif

!include wres.mif

inc_dirs = -I"../h" -I"$(wres_dir)/h" -I"$(trmem_dir)"

.c: ../c;$(trmem_dir);$(watcom_dir)/c

objs = bincmp.obj &
       cmpcont.obj &
       cmpfiles.obj &
       cmpres.obj &
       global.obj &
       layer0.obj &
       param.obj &
       rescmp.obj

objs += trmemcvr.obj trmem.obj

libs = $(wres_lib)

!include exetarg.mif
