!ifndef proj_name
!error proj_name must be defined!
!endif

!ifndef clpp
!error clpp must be defined!
!endif

$(proj_name).exe : $(objs) $(libs) $(cl_objs)
!ifeq verbose 1
        $(clpp) $(clflags) $(objs) $(libs) $(cl_objs) $(cl_libs)
!else
        @echo cl++ $@
        @$(clpp) $(clflags) $(objs) $(libs) $(cl_objs) $(cl_libs)
!endif
